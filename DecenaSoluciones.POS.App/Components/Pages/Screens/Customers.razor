@page "/customers"
@using CurrieTechnologies.Razor.SweetAlert2;
@using DecenaSoluciones.POS.App.Components.Pages.Components
@using DecenaSoluciones.POS.Shared.Dtos;
@using DecenaSoluciones.POS.Shared.Services;
@using Microsoft.AspNetCore.Authorization;
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]
@inject ICustomerService customerService;
@inject SweetAlertService Swal;
@inject NavigationManager navManager;
@inject IJSRuntime JS;

<Modal @ref="RescheduleModal" UseStaticBackdrop="true" Size="ModalSize.Large" OnHidden="OnModalHiding" />

<div class="list-page">

    @* Search Bar *@
    <div class="list-search-bar">
        <i class="rzi rzi-search search-icon"></i>
        <input type="text"
               placeholder="Buscar cliente por nombre..."
               @bind="searchText"
               @bind:event="oninput"
               @onkeyup="OnSearchKeyUp" />
    </div>

    @if (filteredCustomerList != null && filteredCustomerList.Any())
    {
        <div class="list-results-count">@filteredCustomerList.Count() clientes</div>

        @foreach (var customer in GetPagedItems())
        {
            <div class="list-card @GetStatusBorderClass(customer)">
                <div style="flex:1;min-width:0;" @onclick="() => GoToCustomer(customer)">
                    <div class="card-main">
                        <span class="card-title">
                            @customer.Name
                            @if (customer.NextMaintenance.HasValue)
                            {
                                <span class="customer-maintenance-badge @GetBadgeClass(customer)">
                                    @customer.NextMaintenance.Value.ToString("dd/MM/yyyy")
                                </span>
                            }
                        </span>
                        @if (!string.IsNullOrEmpty(customer.Product))
                        {
                            <span class="card-subtitle">@customer.Product</span>
                        }
                        @if (!string.IsNullOrEmpty(customer.Direction))
                        {
                            <span class="card-subtitle">📍 @customer.Direction</span>
                        }
                    </div>
                </div>

                <div class="customer-actions">
                    @if (!string.IsNullOrEmpty(customer.PhoneNumber))
                    {
                        <button type="button"
                                class="action-icon-btn whatsapp"
                                @onclick="() => CallWhatsapp(customer)"
                                title="WhatsApp"
                                aria-label="Contactar por WhatsApp">
                            <img class="action-icon-img" src="images/whatsapp.svg" alt="" aria-hidden="true" />
                        </button>
                        <button type="button"
                                class="action-icon-btn phone"
                                @onclick="() => MakeDirectCall(customer)"
                                title="Llamar"
                                aria-label="Llamar al cliente">
                            <img class="action-icon-img" src="images/phone.svg" alt="" aria-hidden="true" />
                        </button>
                    }
                </div>
            </div>

            @if (customer.NextMaintenance.HasValue)
            {
                <div style="margin-top:-6px;margin-bottom:8px;padding:0 16px;">
                    <button type="button" class="reschedule-link" style="font-size:0.78rem;color:var(--primary-color);font-weight:600;cursor:pointer;text-decoration:underline;background:none;border:none;padding:2px 0;" @onclick="() => ShowRescheduleModal(customer)">
                        Reprogramar mantenimiento
                    </button>
                </div>
            }
        }

        @if (TotalPages > 1)
        {
            <div class="list-pagination">
                <button type="button" disabled="@(currentPage <= 1)" @onclick="() => ChangePage(currentPage - 1)">‹</button>
                @for (int i = Math.Max(1, Math.Min(currentPage - 2, TotalPages - 4)); i <= Math.Min(TotalPages, Math.Max(currentPage + 2, 5)); i++)
                {
                    var pg = i;
                    <button type="button" class="@(pg == currentPage ? "active" : "")" @onclick="() => ChangePage(pg)">@pg</button>
                }
                <button type="button" disabled="@(currentPage >= TotalPages)" @onclick="() => ChangePage(currentPage + 1)">›</button>
            </div>
        }
    }
    else
    {
        <div class="list-empty-state">
            <img src="images/NoResults.png" alt="Sin resultados" />
            <p>No se encontraron clientes para mostrar</p>
        </div>
    }

    <AuthorizeView Roles="admin, manager" Context="authContext">
        <RadzenButton Click="@(() => navManager.NavigateTo("/newcustomer"))" Icon="add" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" Shade="Shade.Darker" class="rz-border-radius-10 rz-shadow-10 floatButtom" />
    </AuthorizeView>
</div>

@code{
    string searchText = "";
    int currentPage = 1;
    int pageSize = 10;
    [Inject] protected PreloadService? PreloadService { get; set; }
    IQueryable<CustomerViewModel> customerList;
    IQueryable<CustomerViewModel> filteredCustomerList;
    private Modal RescheduleModal = default!;

    int TotalPages => filteredCustomerList == null ? 1 : (int)Math.Ceiling(filteredCustomerList.Count() / (double)pageSize);

    IEnumerable<CustomerViewModel> GetPagedItems() =>
        filteredCustomerList?.Skip((currentPage - 1) * pageSize).Take(pageSize) ?? Enumerable.Empty<CustomerViewModel>();

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    protected override async Task OnInitializedAsync()
    {
        await UpdateData();
    }

    private async Task UpdateData()
    {
        try
        {
            PreloadService!.Show();
            var response = await customerService.GetCustomerList();
            PreloadService.Hide();
            if (response.Success)
            {
                customerList = (response.Result!.OrderBy(p => p.NextMaintenance ?? DateOnly.MaxValue).ToList() ?? new List<CustomerViewModel>()).AsQueryable();
                filteredCustomerList = customerList;
            }
            else
            {
                await Swal.FireAsync(new SweetAlertOptions
                    {
                        Title = "Error",
                        Text = response.Message.HandleErrorMessage("Se produjo un error al obtener los clientes."),
                        Icon = SweetAlertIcon.Error
                    });
            }
        }
        catch (Exception ex)
        {
            PreloadService!.Hide();
            await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "Error",
                    Text = ex.Message.HandleErrorMessage("Se produjo un error al obtener los clientes."),
                    Icon = SweetAlertIcon.Error
                });
        }
    }

    private void GoToCustomer(CustomerViewModel customer)
    {
        navManager.NavigateTo($"/newcustomer/{customer.Id}");
    }

    private void OnSearchKeyUp()
    {
        currentPage = 1;
        if (string.IsNullOrEmpty(searchText))
            filteredCustomerList = customerList;
        else
            filteredCustomerList = customerList.Where(p => p.Name.ToLower().Contains(searchText.Trim().ToLower()));
    }

    private string GetStatusBorderClass(CustomerViewModel cust)
    {
        if (cust.NextMaintenance != null)
        {
            var DaysToMaintenance = (cust.NextMaintenance.Value.ToDateTime(TimeOnly.MinValue) - DateTime.Now).TotalDays;
            if (DaysToMaintenance < 15) return "status-border-danger";
            else if (DaysToMaintenance < 30) return "status-border-warning";
        }
        return "status-border-success";
    }

    private string GetBadgeClass(CustomerViewModel cust)
    {
        if (cust.NextMaintenance != null)
        {
            var DaysToMaintenance = (cust.NextMaintenance.Value.ToDateTime(TimeOnly.MinValue) - DateTime.Now).TotalDays;
            if (DaysToMaintenance < 15) return "badge-danger";
            else if (DaysToMaintenance < 30) return "badge-warning";
        }
        return "badge-success";
    }

    private async Task CallWhatsapp(CustomerViewModel customer)
    {
        if (string.IsNullOrEmpty(customer.PhoneNumber))
            return;

        Uri uri = new Uri($"https://api.whatsapp.com/send?phone=1{customer.PhoneNumber.RemovePhoneNumberSpecialCharacters()}");
        await Browser.Default.OpenAsync(uri, BrowserLaunchMode.SystemPreferred);
    }

    private async Task MakeDirectCall(CustomerViewModel customer)
    {
        if (string.IsNullOrEmpty(customer.PhoneNumber))
            return;

        Uri uri = new Uri($"tel:{customer.PhoneNumber.RemovePhoneNumberSpecialCharacters()}");
        await Browser.Default.OpenAsync(uri, BrowserLaunchMode.SystemPreferred);
    }

    private async Task ShowRescheduleModal(CustomerViewModel customer)
    {
        var parameters = new Dictionary<string, object>();
        parameters.Add("CustomerId", customer.Id);
        parameters.Add("OnClose", EventCallback.Factory.Create<MouseEventArgs>(this, HideAddEditCustomerModal));
        await RescheduleModal.ShowAsync<RescheduleComponent>(title: "Reprogramar mantenimiento", parameters: parameters);
    }

    private async Task HideAddEditCustomerModal(MouseEventArgs e)
    {
        await RescheduleModal.HideAsync();
    }

    private async Task OnModalHiding()
    {
        await UpdateData();
    }
}