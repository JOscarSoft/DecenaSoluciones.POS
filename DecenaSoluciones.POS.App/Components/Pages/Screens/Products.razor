@page "/products"
@using CurrieTechnologies.Razor.SweetAlert2;
@using DecenaSoluciones.POS.App.Components.Pages.Components
@using DecenaSoluciones.POS.Shared.Dtos;
@using DecenaSoluciones.POS.Shared.Services;
@using Microsoft.AspNetCore.Authorization;
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization

@attribute [Authorize]
@inject IProductService productService;
@inject SweetAlertService Swal;
@inject NavigationManager navManager;
@inject IJSRuntime JS;

<div class="list-page">

    @* Search Bar *@
    <div class="list-search-bar">
        <i class="rzi rzi-search search-icon"></i>
        <input type="text"
               placeholder="Buscar producto por nombre o código..."
               @bind="searchText"
               @bind:event="oninput"
               @onkeyup="OnSearchKeyUp" />
    </div>

    @if (filteredProductList != null && filteredProductList.Any())
    {
        <div class="list-results-count">@filteredProductList.Count() productos</div>

        @foreach (var product in GetPagedItems())
        {
            <div class="list-card" @onclick="(() => GoToProduct(product))">
                <div class="card-main">
                    <span class="card-title">@product.Description</span>
                    <span class="card-subtitle">@product.Code</span>
                </div>
                <div class="card-right">
                    <span class="card-amount">@product.Price.ToString("C2", CultureInfo.CreateSpecificCulture("en-US"))</span>
                    <span class="card-badge @GetStockBadgeClass(product.stock)">Stock: @product.stock</span>
                </div>
            </div>
        }

        @if (TotalPages > 1)
        {
            <div class="list-pagination">
                <button type="button" disabled="@(currentPage <= 1)" @onclick="() => ChangePage(currentPage - 1)">‹</button>
                @for (int i = Math.Max(1, Math.Min(currentPage - 2, TotalPages - 4)); i <= Math.Min(TotalPages, Math.Max(currentPage + 2, 5)); i++)
                {
                    var pg = i;
                    <button type="button" class="@(pg == currentPage ? "active" : "")" @onclick="() => ChangePage(pg)">@pg</button>
                }
                <button type="button" disabled="@(currentPage >= TotalPages)" @onclick="() => ChangePage(currentPage + 1)">›</button>
            </div>
        }
    }
    else
    {
        <div class="list-empty-state">
            <img src="images/NoResults.png" alt="Sin resultados" />
            <p>No se encontraron productos para mostrar</p>
        </div>
    }

    <AuthorizeView Roles="admin, manager" Context="authContext">
        <RadzenButton Click="@(() => navManager.NavigateTo("/newproduct"))" Icon="add" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" Shade="Shade.Darker" class="rz-border-radius-10 rz-shadow-10 floatButtom" />
    </AuthorizeView>
</div>

@code{
    string searchText = "";
    int currentPage = 1;
    int pageSize = 15;
    [Inject] protected PreloadService? PreloadService { get; set; }
    IQueryable<ProductViewModel> productList;
    IQueryable<ProductViewModel> filteredProductList;

    int TotalPages => filteredProductList == null ? 1 : (int)Math.Ceiling(filteredProductList.Count() / (double)pageSize);

    IEnumerable<ProductViewModel> GetPagedItems() =>
        filteredProductList?.Skip((currentPage - 1) * pageSize).Take(pageSize) ?? Enumerable.Empty<ProductViewModel>();

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    private string GetStockBadgeClass(decimal stock)
    {
        if (stock <= 0) return "badge-stock-empty";
        if (stock <= 5) return "badge-stock-low";
        return "badge-stock-ok";
    }

    protected override async Task OnInitializedAsync()
    {
        await UpdateData();
    }

    private async Task UpdateData()
    {
        try
        {
            PreloadService!.Show();
            var response = await productService.GetProducts();
            PreloadService.Hide();
            if (response.Success)
            {
                productList = (response.Result!.OrderBy(p => p.Description).ToList() ?? new List<ProductViewModel>()).AsQueryable();
                filteredProductList = productList;
            }
            else
            {
                await Swal.FireAsync(new SweetAlertOptions
                    {
                        Title = "Error",
                        Text = response.Message.HandleErrorMessage("Se produjo un error al obtener los productos."),
                        Icon = SweetAlertIcon.Error
                    });
            }
        }
        catch (Exception ex)
        {
            PreloadService!.Hide();
            await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "Error",
                    Text = ex.Message.HandleErrorMessage("Se produjo un error al obtener los productos."),
                    Icon = SweetAlertIcon.Error
                });
        }
    }

    private void GoToProduct(ProductViewModel product)
    {
        navManager.NavigateTo($"/newproduct/{product.Id}");
    }

    private void OnSearchKeyUp()
    {
        currentPage = 1;
        if (string.IsNullOrEmpty(searchText))
            filteredProductList = productList;
        else
            filteredProductList = productList.Where(p =>
                p.Description.ToLower().Contains(searchText.Trim().ToLower()) ||
                p.Code.ToLower().Contains(searchText.Trim().ToLower()));
    }
}