@page "/sales"
@using CurrieTechnologies.Razor.SweetAlert2;
@using DecenaSoluciones.POS.App.Components.Pages.Components
@using DecenaSoluciones.POS.Shared.Dtos;
@using DecenaSoluciones.POS.Shared.Services;
@using Microsoft.AspNetCore.Authorization;
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization

@attribute [Authorize]
@inject SweetAlertService Swal;
@inject NavigationManager navManager;
@inject ISaleService saleService;
@inject IJSRuntime JS;

<div class="list-page">

    @* Search Bar *@
    <div class="list-search-bar">
        <i class="rzi rzi-search search-icon"></i>
        <input type="text"
               placeholder="Buscar por cliente..."
               @bind="searchText"
               @bind:event="oninput"
               @onkeyup="OnSearchKeyUp" />
    </div>

    @if (filteredSalesList != null && filteredSalesList.Any())
    {
        <div class="list-results-count">@filteredSalesList.Count() ventas</div>

        @foreach (var sale in GetPagedItems())
        {
            <div class="list-card" @onclick="(() => GoToSale(sale))">
                <div class="card-main">
                    <span class="card-title">@(string.IsNullOrEmpty(sale.CustomerName) ? sale.Code : sale.CustomerName)</span>
                    <span class="card-subtitle">@sale.Code</span>
                </div>
                <div class="card-right">
                    <span class="card-amount">@(sale.Total != null ? sale.Total.Value.ToString("C2", CultureInfo.CreateSpecificCulture("en-US")) : "$0.00")</span>
                    <span class="card-date">@sale.CreationDate.ToString("dd/MM/yyyy")</span>
                </div>
            </div>
        }

        @if (TotalPages > 1)
        {
            <div class="list-pagination">
                <button type="button" disabled="@(currentPage <= 1)" @onclick="() => ChangePage(currentPage - 1)">‹</button>
                @for (int i = Math.Max(1, Math.Min(currentPage - 2, TotalPages - 4)); i <= Math.Min(TotalPages, Math.Max(currentPage + 2, 5)); i++)
                {
                    var pg = i;
                    <button type="button" class="@(pg == currentPage ? "active" : "")" @onclick="() => ChangePage(pg)">@pg</button>
                }
                <button type="button" disabled="@(currentPage >= TotalPages)" @onclick="() => ChangePage(currentPage + 1)">›</button>
            </div>
        }
    }
    else
    {
        <div class="list-empty-state">
            <img src="images/NoResults.png" alt="Sin resultados" />
            <p>No se encontraron ventas para mostrar</p>
        </div>
    }

    <AuthorizeView Roles="admin, manager" Context="authContext">
        <RadzenButton Click="@(() => navManager.NavigateTo("/newsale"))" Icon="add" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" Shade="Shade.Darker" class="rz-border-radius-10 rz-shadow-10 floatButtom" />
    </AuthorizeView>
</div>

@code{
    [Inject] protected PreloadService? preloadService { get; set; }
    IQueryable<SalesViewModel> saleList;
    IQueryable<SalesViewModel> filteredSalesList { get; set; }
    string searchText = "";
    int currentPage = 1;
    int pageSize = 15;

    int TotalPages => filteredSalesList == null ? 1 : (int)Math.Ceiling(filteredSalesList.Count() / (double)pageSize);

    IEnumerable<SalesViewModel> GetPagedItems() =>
        filteredSalesList?.Skip((currentPage - 1) * pageSize).Take(pageSize) ?? Enumerable.Empty<SalesViewModel>();

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    protected override async Task OnInitializedAsync()
    {
        await UpdateData();
    }

    private async Task UpdateData()
    {
        preloadService!.Show();
        try
        {

            var response = await saleService.GetSalesList();

            preloadService!.Hide();
            if (response.Success)
            {
                saleList = (response.Result?.Where(p => !p.Dismissed) ?? new List<SalesViewModel>()).AsQueryable();
                filteredSalesList = saleList;
            }
            else
            {
                await Swal.FireAsync(new SweetAlertOptions
                    {
                        Title = "Error",
                        Text = response.Message.HandleErrorMessage("Se produjo un error al obtener las ventas."),
                        Icon = SweetAlertIcon.Error
                    });
            }
        }
        catch (Exception ex)
        {
            preloadService!.Hide();
            await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "Error",
                    Text = ex.Message.HandleErrorMessage("Se produjo un error al obtener las ventas."),
                    Icon = SweetAlertIcon.Error
                });
        }
    }

    private void OnSearchKeyUp()
    {
        currentPage = 1;
        if (string.IsNullOrEmpty(searchText))
            filteredSalesList = saleList;
        else
            filteredSalesList = saleList.Where(p => p.CustomerName != null && p.CustomerName.ToLower().Contains(searchText.Trim().ToLower()));
    }

    private void GoToSale(SalesViewModel sale)
    {
        navManager.NavigateTo($"newsale/{sale.Id}/0");
    }
}